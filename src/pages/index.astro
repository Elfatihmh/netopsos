---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<MainLayout title="NetOps OS">
  <Header />

  <main class="page home">
    <p class="label">Network Operations Workbench</p>
    <h1>NetOps OS</h1>
    <h2>Discover. Document. Automate. Operate.</h2>

    <p class="lead">
      A unified engineering workbench for network discovery, infrastructure
      documentation, configuration management, automation, reporting, and
      operational intelligence.
    </p>

    <div class="actions">
      <a class="btn primary" href="/netopsos/capabilities/">Explore Capabilities</a>
      <a class="btn" href="/netopsos/architecture/">View Architecture</a>
    </div>
  </main>

  <Footer />
</MainLayout>
